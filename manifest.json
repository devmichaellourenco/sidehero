{
  "manifest_version": 3,
  "name": "Side Hero — Idle RPG",
  "version": "0.3.0",
  "description": "Heróis batalham no painel lateral do Chrome enquanto você navega normalmente.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "alarms", "tabs", "sidePanel"],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Side Hero — abrir painel lateral"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
