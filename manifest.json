{
  "manifest_version": 3,
  "name": "Side Hero — Idle RPG",
  "version": "0.2.0",
  "description": "Heróis batalham no painel lateral direito enquanto você navega normalmente.",
  "permissions": ["storage", "alarms", "tabs", "scripting", "activeTab"],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Side Hero — mostrar/ocultar painel"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/sidebar-host.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel/*", "content/sidebar-host.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
